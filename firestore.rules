rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email in [
           'aimanaimlengineer@gmail.com',
           'adilabbas812@gmail.com',
           'aimanmaniyar20@gmail.com',
           'adilabbas@gmail.com',
           'aimanmaniyar28@gmail.com'
         ] && request.auth.token.email_verified == true));
    }

    // ✅ NEW: Credit check
    function hasCredits() {
      return isAuthenticated() &&
        (
          isAdmin() || // 🔥 Admin = unlimited
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.credits > 0
        );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function isValidRugConfig(config) {
      return config is map &&
        config.prompt is string &&
        config.colors is list &&
        config.materialTypes is list &&
        config.width is number &&
        config.length is number &&
        config.construction is string &&
        config.pileType is string &&
        config.pileHeight is string &&
        config.surfaceFinishes is list &&
        config.seed is number;
    }

    function isValidDesign(data) {
      return hasRequiredFields(['userId', 'name', 'imageUrl', 'config', 'createdAt']) &&
        data.userId == request.auth.uid &&
        isValidString('name', 1, 1000) &&
        isValidUrl(data.imageUrl) &&
        isValidRugConfig(data.config);
    }

    match /designs/{designId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());

      // 🔥 CREDIT CHECK ADDED HERE
      allow create: if isAuthenticated() && hasCredits() && isValidDesign(request.resource.data);

      allow update: if isAuthenticated() && isDocOwner();
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow update: if isAuthenticated() && isDocOwner();
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());

      allow create: if isOwner(userId);

      allow update: if isOwner(userId) || isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /prompts/{promptId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
